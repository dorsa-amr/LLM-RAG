# OpenAI API Key
OPENAI_API_KEY=your_api_key_here

# Vector DB Settings
VECTOR_DB_PATH=./data/vector_db
CHROMA_DB_PATH=./data/chroma_db

# PubMed Settings
PUBMED_BATCH_SIZE=100
PUBMED_MAX_ARTICLES=500
PUBMED_USE_FULL_TEXT=true
PUBMED_FULL_TEXT_CHAR_LIMIT=20000

# Retrieval Parameters
RETRIEVAL_TOP_K=5
RETRIEVAL_SCORE_THRESHOLD=0.3
CHUNK_SIZE=1000
CHUNK_OVERLAP=200

# LLM Model
MODEL_NAME=gpt-3.5-turbo
TEMPERATURE=0.7
MAX_TOKENS=2000
